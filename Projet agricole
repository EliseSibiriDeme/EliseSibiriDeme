<!doctype html>
<html lang="fr">
<head>
  <!-- Meta de base -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Portfolio de {{AGRIPIK}} — Projets agricoles, produits, données de rendement et contact." />
  <meta name="author" content="{{GODWIN}}" />
  <link rel="canonical" href="https://votre-site.example/" />
  <title>{{PROJET AGRICOLE}} — Portfolio agricole</title>

  <!-- Open Graph -->
  <meta property="og:title" content="{{ELISE SIBIRI}} — Portfolio agricole" />
  <meta property="og:description" content="Projets durables, produits locaux et données de rendement." />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="/assets/img/og-placeholder.jpg" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="{{MyAgroSite}}" />

  <!-- Schema.org -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Farm",
    "name": "{{AGRIPIK}}",
    "image": "{{PIMENT}}",
    "email": "{{elisesibirideme@gmail.com}}",
    "telephone": "{{+22677705128}}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{secteur 42}}"
    },
    "url": "https://votre-site.example"
  }
  </script>

  <!-- Styles -->
  <link rel="stylesheet" href="styles.css" />

  <!-- Scripts externes -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>

  <!-- Icônes inline -->
  <style>
    .icon {font-size:1.1rem; margin-right:.4rem}
    :root {
      --bg: #fff;
      --text: #111;
    }
    [data-theme="dark"] {
      --bg: #111;
      --text: #eee;
    }
    body {
      background: var(--bg);
      color: var(--text);
      transition: background .3s, color .3s;
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="site-header" role="banner">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="{{CHAMPS 🌳}} logo">
        <img src="{{champs de piment}}" alt="{{AGRIPIK}} logo" decoding="async" />
      </a>

      <nav id="main-nav" class="nav" aria-label="Navigation principale">
        <button id="nav-toggle" aria-expanded="false" aria-controls="nav-list" aria-label="Ouvrir le menu">☰</button>
        <ul id="nav-list" class="nav-list">
          <li><a href="#hero" aria-current="page">Accueil</a></li>
          <li><a href="#apropos">À propos</a></li>
          <li><a href="#produits">Produits</a></li>
          <li><a href="#projets">Projets</a></li>
          <li><a href="#donnees">Données</a></li>
          <li><a href="#galerie">Galerie</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>

      <div class="header-actions">
        <a class="btn" href="https://wa.me/{{0022677705128}}" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <button id="theme-toggle" aria-pressed="false" title="Basculer thème">🌓</button>
      </div>
    </div>
  </header>

  <!-- Main -->
  <main id="main" class="site-main">
    <!-- Hero -->
    <section id="hero" class="hero" aria-label="Bannière principale">
      <div class="container hero-grid">
        <div class="hero-content">
          <h1>{{PIMENT,TOMATE,ETC...}}</h1>
          <p class="lead">Pratiques durables • Produits locaux • Résultats mesurables</p>
          <p><a class="btn primary" href="#projets">Découvrir nos projets</a></p>
        </div>

        <figure class="hero-figure">
          <img
            src="/assets/img/hero-small.jpg"
            srcset="/assets/img/hero-small.jpg 600w, /assets/img/hero-medium.jpg 1200w, /assets/img/hero-large.jpg 2000w"
            sizes="(max-width:600px) 100vw, 50vw"
            alt="Paysage de la ferme {{UNE FERME CLÔTURER}}"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <!-- Ici tu gardes les autres sections (À propos, Produits, Projets, Données, Galerie, Contact) 
         avec la même structure que ton code initial mais optimisé avec:
         - images lazy + decoding
         - aria-live pour messages
         - rel="noopener noreferrer" sur liens externes
         - structure DRY avec data-* si tu veux injecter via JS -->
  </main>

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo">
    <div class="container footer-inner">
      <p>© <span id="year"></span> {{Elise sibiri Deme}} — Tous droits réservés.</p>
      <nav aria-label="Réseaux sociaux">
        <a href="#" target="_blank" rel="noopener noreferrer">Facebook</a> •
        <a href="#" target="_blank" rel="noopener noreferrer">Instagram</a>
      </nav>
    </div>
  </footer>

  <!-- Modal -->
  <div id="modal" class="modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-content" role="document">
      <button id="modal-close" class="modal-close" aria-label="Fermer">✕</button>
      <div id="modal-body"></div>
    </div>
  </div>

  <!-- Scripts -->
  <script src="scripts.js"></script>
  <script>
    // Year auto
    document.getElementById("year").textContent = new Date().getFullYear();

    // Dark mode
    const themeBtn = document.getElementById("theme-toggle");
    themeBtn.addEventListener("click", () => {
      document.body.toggleAttribute("data-theme");
      themeBtn.setAttribute("aria-pressed", document.body.hasAttribute("data-theme"));
    });
  </script>
</body>
</html>
